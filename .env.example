# Copy to .env and fill in. Used by docker-compose.yml.

# --- Home Assistant --------------------------------------------------------
# Base URL of your HA instance (http:// is fine on the LAN).
KK_HA_URL=http://192.168.1.10:8123
# Profile (click your name, bottom-left) -> Security tab -> Long-lived access tokens.
KK_HA_TOKEN=paste-your-long-lived-token-here

# Volume goes to the Bose soundbar entity (cavefire/Bose-Homeassistant via HACS).
KK_VOLUME_ENTITY=media_player.bose_soundbar_700
# Track skip / play-pause goes to the Spotify integration entity — it controls
# whatever Spotify Connect is playing on, including the soundbar.
KK_MEDIA_ENTITY=media_player.spotify_yash

# Safety ceiling for gesture-set volume (0.0-1.0). The knob can never blast
# past this, no matter how far you turn.
KK_MAX_VOLUME=0.9

# --- Capture -----------------------------------------------------------------
# auto = detect Kinect v1/v2 on the USB bus; or force kinect1 / kinect2 / webcam.
KK_BACKEND=auto
# Only react to hands between these distances (metres, needs Kinect depth).
KK_USE_DEPTH=true
KK_DEPTH_MIN_M=0.5
KK_DEPTH_MAX_M=3.0
# Kinect v2 night mode: track on the self-illuminated IR camera when the room
# is dark (movie night). auto | off | always
KK_IR_MODE=auto
# Kinect v2 color exposure. `semi:<ms>` caps the shutter so fast hands stay
# sharp in dim light (auto-exposure otherwise stretches to ~33 ms and blurs
# swipes into mush); gain floats to compensate. auto | auto:<ev> | semi:<ms>
# | manual:<ms>,<gain>
KK_EXPOSURE=auto
# Auto-brighten dim frames (gamma lift) before hand tracking — pairs with a
# capped shutter, which trades brightness for sharpness.
KK_LOW_LIGHT_BOOST=true

# --- Gestures ----------------------------------------------------------------
KK_SWIPE_ENABLED=true
# Closed-fist hold = play/pause (off by default):
KK_PLAYPAUSE_ENABLED=false
# Degrees of twist for silent -> full volume (smaller = more sensitive knob):
KK_FULL_SCALE_DEG=270
KK_INVERT_ROTATION=false
# Deep tuning: copy config.example.yaml to config.yaml, uncomment the volume
# in docker-compose.yml, then set:
#KK_CONFIG=/app/config.yaml

# --- GPU (Kinect v2 only) ----------------------------------------------------
# `nvidia-smi -L` on the Unraid host, copy the UUID of the card to dedicate:
# GPU 0: NVIDIA GeForce GTX 1080 Ti (UUID: GPU-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
GPU_UUID=all

KK_LOG_LEVEL=INFO
