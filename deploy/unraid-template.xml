<?xml version="1.0"?>
<!-- Unraid dockerMan user template.
     Copy to /boot/config/plugins/dockerMan/templates-user/my-kinect-knob.xml
     then Add Container -> Template -> kinect-knob.
     NOTE: dockerMan cannot build images. Build once on the box first:
       docker build -t kinect-knob:local /mnt/user/appdata/kinect-knob
     (Or skip templates entirely and use the docker-compose.yml with the
     Compose Manager Plus plugin, which builds for you.)
     KINECT V1 (Xbox 360) OWNERS: no GPU is used - remove `--runtime=nvidia`
     from ExtraParams below, or container creation fails on hosts without
     the Nvidia-Driver plugin's runtime. -->
<Container version="2">
  <Name>kinect-knob</Name>
  <Repository>kinect-knob:local</Repository>
  <Registry/>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/</Support>
  <Overview>Hand-gesture volume knob: an Xbox Kinect watches for a pinch-and-twist motion and sets your Bose Soundbar 700 volume through Home Assistant. Open-palm swipes skip Spotify tracks. Web UI on port 8420.</Overview>
  <Category>HomeAutomation:</Category>
  <WebUI>http://[IP]:[PORT:8420]/</WebUI>
  <ExtraParams>--runtime=nvidia -v /dev/bus/usb:/dev/bus/usb --device-cgroup-rule='c 189:* rmw' --restart=unless-stopped</ExtraParams>
  <PostArgs/>
  <Config Name="Web UI Port" Target="8420" Default="8420" Mode="tcp" Type="Port" Display="always" Required="true" Mask="false">8420</Config>
  <Config Name="Home Assistant URL" Target="KK_HA_URL" Default="http://192.168.1.10:8123" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Home Assistant Token" Target="KK_HA_TOKEN" Default="" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Volume Entity (Bose)" Target="KK_VOLUME_ENTITY" Default="media_player.bose_soundbar_700" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Media Entity (Spotify)" Target="KK_MEDIA_ENTITY" Default="media_player.spotify_myaccount" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Max Volume 0-1" Target="KK_MAX_VOLUME" Default="0.9" Type="Variable" Display="always" Required="false" Mask="false">0.9</Config>
  <Config Name="Capture Backend" Target="KK_BACKEND" Default="auto" Type="Variable" Display="advanced" Required="false" Mask="false">auto</Config>
  <Config Name="GPU UUID (nvidia-smi -L)" Target="NVIDIA_VISIBLE_DEVICES" Default="all" Type="Variable" Display="always" Required="false" Mask="false">all</Config>
  <Config Name="NVIDIA Capabilities" Target="NVIDIA_DRIVER_CAPABILITIES" Default="compute,utility" Type="Variable" Display="advanced" Required="false" Mask="false">compute,utility</Config>
  <Config Name="Depth Min (m)" Target="KK_DEPTH_MIN_M" Default="0.5" Type="Variable" Display="advanced" Required="false" Mask="false">0.5</Config>
  <Config Name="Depth Max (m)" Target="KK_DEPTH_MAX_M" Default="3.0" Type="Variable" Display="advanced" Required="false" Mask="false">3.0</Config>
  <Config Name="Log Level" Target="KK_LOG_LEVEL" Default="INFO" Type="Variable" Display="advanced" Required="false" Mask="false">INFO</Config>
</Container>
